{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "0xoLemon",
    "version":  "0.2.10",
    "identifier":  "0xoLemon",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "beforeBuildCommand":  "npm run build",
                  "devUrl":  "http://localhost:1420",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "0xoLemon",
                                    "width":  1440,
                                    "height":  900,
                                    "minWidth":  1120,
                                    "minHeight":  720,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "visible":  false,
                                    "decorations":  false,
                                    "transparent":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "createUpdaterArtifacts":  true,
                   "resources":  [
                                     "assets/**/*"
                                 ],
                   "icon":  [
                                "icons/icon.ico"
                            ]
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCNDVDODI1MThGRUY5QUEKUldTcStmNFlKY2hGaTJSV0tna3IzMGhWTHlxWC9hM0dlclJ6c0dhUEtDKzBNN1NYS3NMeDlrZysK",
                                    "endpoints":  [
                                                      "https://github.com/dangjimmy33-dotcom/0xoLemon-Launcher/releases/latest/download/latest.json"
                                                  ],
                                    "windows":  {
                                                    "installMode":  "passive"
                                                }
                                }
