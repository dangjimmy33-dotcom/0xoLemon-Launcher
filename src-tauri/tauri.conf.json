{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "0xoLemon",
  "version": "2.0.1",
  "identifier": "com.0xolemon.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "overlay",
        "title": "Overlay",
        "url": "/overlay",
        "width": 1920,
        "height": 1080,
        "fullscreen": false,
        "resizable": false,
        "alwaysOnTop": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/DepotDownloaderMod"
    ],
    "resources": [
      "resources/steam_hooks/*",
      "resources/cloud_redirect/*",
      "resources/emu/**/*",
      "../steam_appids_mapping.json"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCNDVDODI1MThGRUY5QUEKUldTcStmNFlKY2hGaTJSV0tna3IzMGhWTHlxWC9hM0dlclJ6c0dhUEtDKzBNN1NYS3NMeDlrZysK",
      "endpoints": [
        "https://github.com/dangjimmy33-dotcom/0xoLemon-Launcher/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "interactive"
      }
    }
  }
}
