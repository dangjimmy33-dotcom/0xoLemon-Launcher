{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "0xoLemon",
  "version": "0.1.0",
  "identifier": "0xoLemon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "0xoLemon",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "assets/**/*"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
